{
  "name": "server-manager",
  "version": "1.0.0",
  "description": "Desktop app to manage your servers, what they do, their connections, and credentials.",
  "main": "main.js",
  "author": "v0idxyz",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "net.revbid.servermanager",
    "productName": "Server Manager",
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "v0idxyz",
        "repo": "server-manager",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
